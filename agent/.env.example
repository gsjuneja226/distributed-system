# easycompute Agent Configuration
# -------------------------------

# The IP address of the server machine in the lab
SERVER_IP=192.168.1.227

# URL of the main easycompute API
SCHEDULER_URL=http://192.168.1.227:8000

# Your personal JWT token (copy from the 'Contribute' page on the dashboard)
USER_TOKEN=YOUR_TOKEN_HERE

# Docker registry for pulling research images
DOCKER_REGISTRY=192.168.1.227:5000

# Leave these empty; they will be automatically filled by the agent upon registration
NODE_ID=
NODE_TOKEN=
